{
  "name": "scraper-challenge",
  "version": "1.0.0",
  "description": "Scraper para Repositorio Digital OEFA — Resoluciones TFA",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "start:tfa": "ts-node src/index.ts --site=tfa",
    "start:dfsai": "ts-node src/index.ts --site=dfsai",
    "demo": "ts-node src/index.ts --site=tfa --pages=3",
    "demo:no-pdfs": "ts-node src/index.ts --site=tfa --pages=5 --skip-pdfs",
    "status": "ts-node src/status.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "audit": "pnpm audit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/tough-cookie": "^4.0.5",
    "@vitest/coverage-v8": "^4.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
