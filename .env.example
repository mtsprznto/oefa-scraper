# Sitio objetivo: "dfsai" (sin VPN) | "tfa" (requiere IP peruana)
TARGET_SITE=dfsai

# URL base del servidor — no incluir trailing slash
BASE_URL=https://publico.oefa.gob.pe

# Delays entre requests (ms) — respetar el servidor
# Con múltiples workers usar --delay-multiplier=N por CLI en vez de cambiar estos valores:
#   1 worker  → --delay-multiplier=1.0  (1.5–3.5s entre requests)
#   2 workers → --delay-multiplier=1.5  (2.25–5.25s)
#   3 workers → --delay-multiplier=2.0  (3–7s)
#   4 workers → --delay-multiplier=2.5  (3.75–8.75s)
DELAY_MIN_MS=1500
DELAY_MAX_MS=3500

# Directorio de salida para PDFs descargados
DOWNLOAD_DIR=./downloads

# Directorio de salida para datos extraídos y estado
DATA_DIR=./data
